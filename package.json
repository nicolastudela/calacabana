{
  "name": "calacabana",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "prisma:db:push": "dotenv -e .env.local -- npx prisma db push",
    "prisma:db:seed": "dotenv -e .env.local -- npx prisma db seed",
    "prisma:db:migrate:dev": "dotenv -e .env.local -- npx prisma migrate dev",
    "prisma:db:migrate:reset": "dotenv -e .env.local -- npx prisma migrate reset",
    "prisma:db:migrate:deploy": "dotenv -e .env.local -- npx prisma migrate deploy"
  },
  "prisma": {
    "seed": "ts-node --project ./prisma/tsconfig.json ./prisma/seed.ts"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.1.1",
    "@chakra-ui/react": "^2.8.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@fontsource/montecarlo": "^5.0.8",
    "@fontsource/montserrat": "^5.0.19",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.4",
    "date-fns": "^2.30.0",
    "framer-motion": "^11.11.17",
    "googleapis": "^144.0.0",
    "is-mobile": "^3.1.1",
    "next": "^14.2.18",
    "next-connect": "^1.0.0",
    "nuka-carousel": "^5.0.16",
    "react": "^18.3.1",
    "react-datepicker": "^7.5.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-icons": "^5.3.0",
    "sharp": "^0.33.5",
    "swr": "^2.2.5"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.18",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-datepicker": "^6.0.0",
    "@types/react-dom": "^18.3.1",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
